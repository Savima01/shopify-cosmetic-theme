{%- style -%}
  #aphoria-bs-{{ section.id }} {
    background: {{ section.settings.bg_color }};
  }
  #aphoria-bs-{{ section.id }} .aphoria-bs__heading,
  #aphoria-bs-{{ section.id }} .aphoria-bs__heading p,
  #aphoria-bs-{{ section.id }} .aphoria-bs__heading h1,
  #aphoria-bs-{{ section.id }} .aphoria-bs__heading h2,
  #aphoria-bs-{{ section.id }} .aphoria-bs__heading h3,
  #aphoria-bs-{{ section.id }} .aphoria-bs__heading em,
  #aphoria-bs-{{ section.id }} .aphoria-bs__heading strong {
    color: {{ section.settings.heading_color }};
    font-family: var(--font-heading-family);
    font-style: italic;
    font-size: var(--aphoria-h2);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0;
  }
  #aphoria-bs-{{ section.id }} .aphoria-bs__text {
    color: {{ section.settings.text_color }};
  }
  #aphoria-bs-{{ section.id }} .aphoria-bs__eyebrow {
    color: {{ section.settings.eyebrow_color }};
  }
  #aphoria-bs-{{ section.id }} .aphoria-bs__value-title {
    color: {{ section.settings.value_title_color }};
  }
  #aphoria-bs-{{ section.id }} .aphoria-bs__media-accent {
    background: linear-gradient(135deg, {{ section.settings.accent_color | color_modify: 'alpha', 0.28 }} 0%, transparent 60%);
  }
{%- endstyle -%}

<section class="aphoria-bs" id="aphoria-bs-{{ section.id }}">
  <div class="aphoria-bs__inner">

    <div class="aphoria-bs__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            class: 'aphoria-bs__img',
            loading: 'lazy',
            widths: '400,600,800,1000,1200',
            sizes: '(min-width: 990px) 50vw, 100vw'
        }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'aphoria-bs__placeholder' }}
      {%- endif -%}
      <div class="aphoria-bs__media-accent"></div>
    </div>

    <div class="aphoria-bs__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="aphoria-label aphoria-bs__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <div class="aphoria-heading aphoria-bs__heading" role="heading" aria-level="2">{{ section.settings.heading }}</div>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="aphoria-bs__text aphoria-body">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="aphoria-bs__values">
          {%- for block in section.blocks -%}
            <div class="aphoria-bs__value" {{ block.shopify_attributes }}>
              <span class="aphoria-bs__value-icon">{{ block.settings.icon }}</span>
              <div>
                <p class="aphoria-bs__value-title">{{ block.settings.title | escape }}</p>
                <p class="aphoria-bs__value-desc">{{ block.settings.description | escape }}</p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '/pages/about' }}" class="aphoria-btn aphoria-btn--ghost">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% stylesheet %}
.aphoria-bs {
  background: #0A0205;
  overflow: hidden;
}

.aphoria-bs__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 680px;
}

@media (max-width: 989px) {
  .aphoria-bs__inner { grid-template-columns: 1fr; }
}

.aphoria-bs__media {
  position: relative;
  overflow: hidden;
}

.aphoria-bs__img,
.aphoria-bs__placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.aphoria-bs__media-accent {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(124,29,60,0.28) 0%, transparent 60%);
  pointer-events: none;
}

@media (max-width: 989px) {
  .aphoria-bs__media { min-height: 360px; }
}

.aphoria-bs__content {
  padding: clamp(48px, 8vw, 100px) clamp(32px, 6vw, 80px);
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 28px;
}

.aphoria-bs__eyebrow {
  font-size: var(--aphoria-label-sz);
  letter-spacing: 0.25em;
}

.aphoria-bs__heading {
  font-size: var(--aphoria-h2);
  font-family: var(--font-heading-family);
  font-style: italic;
  font-weight: 400;
  letter-spacing: 0;
  line-height: 1.1;
}

.aphoria-bs__text {
  font-family: var(--font-body-family);
  font-size: var(--aphoria-body-lg);
  font-weight: 300;
  line-height: 1.85;
  max-width: 480px;
}

.aphoria-bs__values {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.aphoria-bs__value {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.aphoria-bs__value-icon {
  font-size: 20px;
  line-height: 1;
  flex-shrink: 0;
  margin-top: 3px;
  opacity: 0.85;
}

.aphoria-bs__value-title {
  font-family: var(--font-heading-family);
  font-size: var(--aphoria-h3);
  font-style: italic;
  font-weight: 400;
  margin-bottom: 3px;
  line-height: 1.2;
}

.aphoria-bs__value-desc {
  font-family: var(--font-body-family);
  font-size: 12px;
  font-weight: 300;
  letter-spacing: 0.04em;
  color: rgba(242, 208, 200, 0.55);
  line-height: 1.6;
}
{% endstylesheet %}

