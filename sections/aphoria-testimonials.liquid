<section class="aphoria-tm" id="aphoria-tm-{{ section.id }}">
  <div class="aphoria-tm__inner aphoria-container">

    {%- if section.settings.eyebrow != blank -%}
      <p class="aphoria-label aphoria-tm__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="aphoria-heading aphoria-tm__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="aphoria-tm__track" id="tm-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="aphoria-tm__slide{% if forloop.first %} is-active{% endif %}"
               data-index="{{ forloop.index0 }}"
               {{ block.shopify_attributes }}>

            <div class="aphoria-tm__stars" aria-label="{{ block.settings.rating }} von 5 Sternen">
              {%- assign rating = block.settings.rating | default: 5 | times: 1 -%}
              {%- for i in (1..5) -%}
                <span class="aphoria-tm__star{% if i > rating %} aphoria-tm__star--empty{% endif %}">★</span>
              {%- endfor -%}
            </div>

            <blockquote class="aphoria-tm__quote">
              <p>{{ block.settings.quote | escape }}</p>
            </blockquote>

            <footer class="aphoria-tm__author">
              <span class="aphoria-tm__name">{{ block.settings.name | escape }}</span>
              {%- if block.settings.subtitle != blank -%}
                <span class="aphoria-tm__subtitle">{{ block.settings.subtitle | escape }}</span>
              {%- endif -%}
              {%- if block.settings.product != blank -%}
                <span class="aphoria-tm__product">{{ block.settings.product | escape }}</span>
              {%- endif -%}
            </footer>

          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <div class="aphoria-tm__dots" role="tablist" aria-label="Testimonials">
          {%- for block in section.blocks -%}
            <button class="aphoria-tm__dot{% if forloop.first %} is-active{% endif %}"
                    data-target="{{ forloop.index0 }}"
                    data-track="tm-track-{{ section.id }}"
                    role="tab"
                    aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                    aria-label="Testimonial {{ forloop.index }}">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}

  </div>
</section>

<script>
(function() {
  document.querySelectorAll('.aphoria-tm__dot').forEach(function(dot) {
    dot.addEventListener('click', function() {
      var trackId = this.dataset.track;
      var idx = parseInt(this.dataset.target, 10);
      var track = document.getElementById(trackId);
      if (!track) return;

      track.querySelectorAll('.aphoria-tm__slide').forEach(function(s, i) {
        s.classList.toggle('is-active', i === idx);
      });

      var allDots = document.querySelectorAll('[data-track="' + trackId + '"]');
      allDots.forEach(function(d, i) {
        d.classList.toggle('is-active', i === idx);
        d.setAttribute('aria-selected', i === idx ? 'true' : 'false');
      });
    });
  });
})();
</script>

{% stylesheet %}
.aphoria-tm {
  background: var(--aphoria-bordeaux);
  padding: clamp(72px, 10vw, 120px) 0;
  overflow: hidden;
  position: relative;
}

.aphoria-tm::before {
  content: '\201C';
  position: absolute;
  top: -20px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-heading-family);
  font-size: clamp(160px, 20vw, 280px);
  font-style: italic;
  color: rgba(10, 2, 5, 0.12);
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

.aphoria-tm__inner {
  text-align: center;
  max-width: 820px;
}

.aphoria-tm__eyebrow {
  color: var(--aphoria-gold);
  margin-bottom: 16px;
}

.aphoria-tm__heading {
  font-size: var(--aphoria-h2);
  color: var(--aphoria-rose-copper);
  margin-bottom: 52px;
}

.aphoria-tm__track {
  position: relative;
  min-height: 220px;
}

.aphoria-tm__slide {
  display: none;
  animation: tm-fade 0.5s ease;
}

.aphoria-tm__slide.is-active {
  display: block;
}

@keyframes tm-fade {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

.aphoria-tm__stars {
  display: flex;
  justify-content: center;
  gap: 4px;
  margin-bottom: 28px;
}

.aphoria-tm__star {
  color: var(--aphoria-gold);
  font-size: 18px;
  line-height: 1;
}

.aphoria-tm__star--empty {
  color: rgba(201, 165, 126, 0.3);
}

.aphoria-tm__quote {
  margin: 0 0 32px;
}

.aphoria-tm__quote p {
  font-family: var(--font-heading-family);
  font-style: italic;
  font-size: clamp(18px, 2.5vw, 26px);
  font-weight: 400;
  color: var(--aphoria-rose-copper);
  line-height: 1.7;
  letter-spacing: 0;
}

.aphoria-tm__author {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.aphoria-tm__author::before {
  content: '';
  display: block;
  width: 32px;
  height: 1px;
  background: var(--aphoria-gold);
  margin-bottom: 12px;
}

.aphoria-tm__name {
  font-family: var(--font-body-family);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--aphoria-gold);
}

.aphoria-tm__subtitle {
  font-family: var(--font-body-family);
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.12em;
  color: rgba(242, 208, 200, 0.55);
  text-transform: uppercase;
}

.aphoria-tm__product {
  font-family: var(--font-body-family);
  font-size: 9px;
  font-weight: 500;
  letter-spacing: 0.15em;
  color: rgba(201, 165, 126, 0.65);
  text-transform: uppercase;
  margin-top: 2px;
}

.aphoria-tm__dots {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 44px;
}

.aphoria-tm__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  border: 1px solid var(--aphoria-gold);
  background: transparent;
  cursor: pointer;
  padding: 0;
  transition: background 0.25s ease, transform 0.25s ease;
}

.aphoria-tm__dot.is-active {
  background: var(--aphoria-gold);
  transform: scale(1.3);
}
{% endstylesheet %}

