{%- style -%}
  .aphoria-split {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }

  .aphoria-split__inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.gap }}px;
    align-items: center;
  }

  @media screen and (max-width: 749px) {
    .aphoria-split__inner {
      grid-template-columns: 1fr;
    }

    .aphoria-split__image-col {
      order: {{ section.settings.image_order_mobile }};
    }

    .aphoria-split__content-col {
      order: {{ section.settings.content_order_mobile }};
    }
  }

  {%- if section.settings.image_side == 'right' -%}
    .aphoria-split__image-col { order: 2; }
    .aphoria-split__content-col { order: 1; }
  {%- endif -%}

  .aphoria-split__image-wrap {
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.image_ratio }};
  }

  .aphoria-split__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .aphoria-split__image-placeholder {
    width: 100%;
    height: 100%;
    background: {{ section.settings.placeholder_color }};
    aspect-ratio: {{ section.settings.image_ratio }};
    border-radius: {{ section.settings.image_radius }}px;
  }

  .aphoria-split__eyebrow {
    font-family: var(--font-body-family);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1.2rem;
  }

  .aphoria-split__heading {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-weight: 400;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .aphoria-split__subtext {
    font-family: var(--font-body-family);
    font-size: 14px;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    margin-bottom: 2.4rem;
    line-height: 1.6;
  }

  .aphoria-split__products {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .aphoria-split__product-card {
    background: {{ section.settings.card_bg }};
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: transform 0.25s ease;
  }

  .aphoria-split__product-card:hover {
    transform: translateY(-3px);
  }

  .aphoria-split__product-img {
    aspect-ratio: 1;
    overflow: hidden;
  }

  .aphoria-split__product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .aphoria-split__product-card:hover .aphoria-split__product-img img {
    transform: scale(1.04);
  }

  .aphoria-split__product-img-placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: {{ section.settings.placeholder_color }};
  }

  .aphoria-split__product-info {
    padding: 1.2rem;
  }

  .aphoria-split__product-vendor {
    font-family: var(--font-body-family);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 0.4rem;
  }

  .aphoria-split__product-title {
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 500;
    color: {{ section.settings.text_color }};
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }

  .aphoria-split__product-price {
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 600;
    color: {{ section.settings.text_color }};
  }
{%- endstyle -%}

{%- assign collection = collections[section.settings.collection] -%}
{%- assign products_to_show = section.settings.products_to_show -%}

<div class="aphoria-split">
  <div class="aphoria-split__inner">

    <div class="aphoria-split__image-col">
      {%- if section.settings.image != blank -%}
        <div class="aphoria-split__image-wrap">
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        </div>
      {%- else -%}
        <div class="aphoria-split__image-placeholder"></div>
      {%- endif -%}
    </div>

    <div class="aphoria-split__content-col">
      {%- if section.settings.eyebrow != blank -%}
        <p class="aphoria-split__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="aphoria-split__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="aphoria-split__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}

      {%- if collection != blank -%}
        <div class="aphoria-split__products">
          {%- for product in collection.products limit: products_to_show -%}
            <a class="aphoria-split__product-card" href="{{ product.url }}">
              <div class="aphoria-split__product-img">
                {%- if product.featured_image != blank -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 500 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                    width="500"
                    height="500"
                  >
                {%- else -%}
                  <div class="aphoria-split__product-img-placeholder"></div>
                {%- endif -%}
              </div>
              <div class="aphoria-split__product-info">
                {%- if section.settings.show_vendor -%}
                  <p class="aphoria-split__product-vendor">{{ product.vendor }}</p>
                {%- endif -%}
                <p class="aphoria-split__product-title">{{ product.title }}</p>
                <p class="aphoria-split__product-price">{{ product.price | money }}</p>
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Lookbook Split",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Bild"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle-Foto"
    },
    {
      "type": "select",
      "id": "image_side",
      "label": "Bild-Position",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Bild-Format",
      "options": [
        { "value": "3/4", "label": "Hochformat (3:4)" },
        { "value": "1/1", "label": "Quadrat (1:1)" },
        { "value": "4/3", "label": "Querformat (4:3)" }
      ],
      "default": "3/4"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Ecken-Rundung (px)",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "Texte"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-Text",
      "default": "Unsere Kollektion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Hautpflege Ritual"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Schriftgröße Überschrift (px)",
      "min": 24,
      "max": 64,
      "step": 2,
      "default": 40
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Beschreibung",
      "default": "Entdecke unsere Bestseller — sorgfältig entwickelt für anspruchsvolle Haut."
    },
    {
      "type": "header",
      "content": "Produkte"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl Produkte",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Markenname anzeigen",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Abstand zwischen Bild und Inhalt (px)",
      "min": 20,
      "max": 100,
      "step": 10,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#FAF6F3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#0A0205"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akzentfarbe (Eyebrow, Vendor)",
      "default": "#7C1D3C"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Produktkarte Hintergrund",
      "default": "#F2D0C8"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Platzhalter-Farbe",
      "default": "#F2D0C8"
    }
  ],
  "presets": [
    {
      "name": "Lookbook Split"
    }
  ]
}
{% endschema %}
