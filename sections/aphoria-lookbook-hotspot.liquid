{%- style -%}
  .aphoria-hotspot {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
  }

  .aphoria-hotspot__inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .aphoria-hotspot__label {
    text-align: center;
    font-family: var(--font-body-family);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1.2rem;
  }

  .aphoria-hotspot__heading {
    text-align: center;
    font-family: var(--font-heading-family);
    font-style: italic;
    font-weight: 400;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.text_color }};
    margin: 0 0 2.4rem;
  }

  .aphoria-hotspot__wrap {
    position: relative;
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
  }

  .aphoria-hotspot__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .aphoria-hotspot__img-placeholder {
    width: 100%;
    aspect-ratio: 16/9;
    background: {{ section.settings.placeholder_color }};
  }

  /* Pin */
  .aphoria-hotspot__pin {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 10;
  }

  .aphoria-hotspot__pin-dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: {{ section.settings.pin_color }};
    border: 2px solid #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }

  .aphoria-hotspot__pin-dot::after {
    content: '+';
    color: #fff;
    font-size: 16px;
    font-weight: 300;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .aphoria-hotspot__pin.is-open .aphoria-hotspot__pin-dot::after {
    transform: rotate(45deg);
  }

  .aphoria-hotspot__pin-dot:hover {
    transform: scale(1.15);
  }

  /* Popup */
  .aphoria-hotspot__popup {
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    border-radius: 12px;
    padding: 1.2rem;
    width: 200px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    display: none;
    text-decoration: none;
  }

  .aphoria-hotspot__pin.is-open .aphoria-hotspot__popup {
    display: block;
  }

  .aphoria-hotspot__popup-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 8px;
    display: block;
    margin-bottom: 0.8rem;
  }

  .aphoria-hotspot__popup-title {
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 600;
    color: #0A0205;
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  .aphoria-hotspot__popup-price {
    font-family: var(--font-body-family);
    font-size: 12px;
    color: {{ section.settings.accent_color }};
  }
{%- endstyle -%}

<div class="aphoria-hotspot">
  <div class="aphoria-hotspot__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="aphoria-hotspot__label">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="aphoria-hotspot__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="aphoria-hotspot__wrap">
      {%- if section.settings.image != blank -%}
        <img
          class="aphoria-hotspot__img"
          src="{{ section.settings.image | image_url: width: 1600 }}"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="aphoria-hotspot__img-placeholder"></div>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- assign product = all_products[block.settings.product] -%}
        <div
          class="aphoria-hotspot__pin"
          style="left: {{ block.settings.pos_x }}%; top: {{ block.settings.pos_y }}%;"
          {{ block.shopify_attributes }}
        >
          <div class="aphoria-hotspot__pin-dot" onclick="this.closest('.aphoria-hotspot__pin').classList.toggle('is-open')"></div>

          {%- if product != blank -%}
            <a class="aphoria-hotspot__popup" href="{{ product.url }}">
              {%- if product.featured_image != blank -%}
                <img
                  class="aphoria-hotspot__popup-img"
                  src="{{ product.featured_image | image_url: width: 300 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                >
              {%- endif -%}
              <p class="aphoria-hotspot__popup-title">{{ product.title }}</p>
              <p class="aphoria-hotspot__popup-price">{{ product.price | money }}</p>
            </a>
          {%- elsif block.settings.label != blank -%}
            <div class="aphoria-hotspot__popup">
              <p class="aphoria-hotspot__popup-title">{{ block.settings.label }}</p>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.aphoria-hotspot__pin-dot')) {
      document.querySelectorAll('.aphoria-hotspot__pin.is-open').forEach(function(pin) {
        pin.classList.remove('is-open');
      });
    }
  });
</script>

{% schema %}
{
  "name": "Lookbook Shoppable Bild",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle-Bild"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-Text",
      "default": "Shop the Look"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Entdecke den Look"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Schriftgröße Überschrift (px)",
      "min": 24,
      "max": 60,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "radius",
      "label": "Ecken-Rundung (px)",
      "min": 0,
      "max": 32,
      "step": 4,
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten (px)",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#0A0205"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#FAF6F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akzentfarbe",
      "default": "#C9A57E"
    },
    {
      "type": "color",
      "id": "pin_color",
      "label": "Pin-Farbe",
      "default": "#7C1D3C"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Platzhalter-Farbe",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Produkt-Pin",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Beschriftung (falls kein Produkt gewählt)"
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Position horizontal (%)",
          "min": 5,
          "max": 95,
          "step": 1,
          "default": 30
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Position vertikal (%)",
          "min": 5,
          "max": 95,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook Shoppable Bild",
      "blocks": [
        {
          "type": "hotspot",
          "settings": { "pos_x": 25, "pos_y": 40 }
        },
        {
          "type": "hotspot",
          "settings": { "pos_x": 65, "pos_y": 60 }
        }
      ]
    }
  ]
}
{% endschema %}
