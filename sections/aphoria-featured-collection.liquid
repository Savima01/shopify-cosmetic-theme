{%- style -%}
  #aphoria-fc-{{ section.id }} {
    --fc-bg: {{ section.settings.bg_color }};
    --fc-cols: {{ section.settings.columns }};
  }
{%- endstyle -%}

<section id="aphoria-fc-{{ section.id }}" class="aphoria-fc">
  <div class="aphoria-container">

    {%- if section.settings.eyebrow != blank -%}
      <p class="aphoria-label aphoria-fc__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="aphoria-heading aphoria-fc__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- assign col = collections[section.settings.collection] -%}
    {%- assign products = col.products | default: (1..4) -%}

    <div class="aphoria-fc__grid">
      {%- for product in products limit: section.settings.products_to_show -%}
        <a href="{{ product.url }}" class="aphoria-fc__card">
          <div class="aphoria-fc__card-media">
            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 800
                | image_tag:
                  class: 'aphoria-fc__card-img',
                  loading: 'lazy',
                  widths: '300,400,600,800',
                  sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw'
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'aphoria-fc__card-placeholder' }}
            {%- endif -%}
            <div class="aphoria-fc__card-overlay">
              <span class="aphoria-btn aphoria-btn--ghost aphoria-fc__quick-view">
                {{ 'sections.aphoria_fc.quick_view' | t }}
              </span>
            </div>
          </div>
          <div class="aphoria-fc__card-info">
            <p class="aphoria-fc__card-vendor aphoria-label">{{ product.vendor }}</p>
            <h3 class="aphoria-fc__card-title">{{ product.title }}</h3>
            <p class="aphoria-fc__card-price">{{ product.price | money }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="aphoria-fc__cta">
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="aphoria-btn aphoria-btn--noir">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.aphoria-fc {
  background: var(--fc-bg, #FAF6F3);
  padding: clamp(60px, 8vw, 120px) 0;
}

.aphoria-fc__eyebrow {
  color: #7C1D3C;
  margin-bottom: 12px;
  text-align: center;
}

.aphoria-fc__heading {
  font-size: clamp(28px, 4vw, 52px);
  color: #0A0205;
  text-align: center;
  margin-bottom: clamp(40px, 6vw, 72px);
}

.aphoria-fc__grid {
  display: grid;
  grid-template-columns: repeat(var(--fc-cols, 4), 1fr);
  gap: 24px;
}

@media (max-width: 989px) {
  .aphoria-fc__grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 599px) {
  .aphoria-fc__grid { grid-template-columns: 1fr; gap: 32px; }
}

.aphoria-fc__card {
  text-decoration: none;
  color: inherit;
  display: block;
}

.aphoria-fc__card-media {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: #F2D0C8;
  margin-bottom: 16px;
}

.aphoria-fc__card-img,
.aphoria-fc__card-placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  display: block;
}

.aphoria-fc__card:hover .aphoria-fc__card-img,
.aphoria-fc__card:hover .aphoria-fc__card-placeholder {
  transform: scale(1.05);
}

.aphoria-fc__card-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 2, 5, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.aphoria-fc__card:hover .aphoria-fc__card-overlay {
  opacity: 1;
}

.aphoria-fc__quick-view {
  font-size: 12px;
  padding: 10px 20px;
  pointer-events: none;
}

.aphoria-fc__card-vendor {
  color: #7C1D3C;
  margin-bottom: 4px;
  font-size: 10px;
}

.aphoria-fc__card-title {
  font-family: 'Bodoni Moda', Georgia, serif;
  font-size: clamp(15px, 1.5vw, 18px);
  font-weight: 400;
  color: #0A0205;
  margin-bottom: 6px;
  line-height: 1.3;
}

.aphoria-fc__card-price {
  font-size: 14px;
  color: #7C1D3C;
  font-weight: 500;
}

.aphoria-fc__cta {
  text-align: center;
  margin-top: clamp(40px, 5vw, 64px);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Aphoria Kollektion",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-Text",
      "default": "Unsere Bestseller"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Die Kollektion"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl Produkte",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Spalten (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#FAF6F3"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Alle Produkte ansehen"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Aphoria Kollektion",
      "settings": {
        "eyebrow": "Unsere Bestseller",
        "heading": "Die Kollektion",
        "products_to_show": 4,
        "columns": 4,
        "button_label": "Alle Produkte ansehen"
      }
    }
  ]
}
{% endschema %}
